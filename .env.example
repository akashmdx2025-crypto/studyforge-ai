# ─────────────────────────────────────────────────────────────────────────────
# StudyForge AI — Environment Variables Template
#
# ⚠️  NEVER put real API keys in this file.
# ⚠️  Copy this to .env.local and fill in your real values.
# ⚠️  .env.local is git-ignored and will NEVER be committed.
#
# Setup:
#   cp .env.example .env.local
#   Then edit .env.local with your actual keys.
# ─────────────────────────────────────────────────────────────────────────────

# Required — get yours at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Legacy (OpenAI)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional overrides
# NODE_ENV=development
# MAX_FILE_SIZE=10485760
