# ─── Environment (NEVER commit real keys) ───────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Allow only the safe example template
!.env.example

# ─── Dependencies ────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing ─────────────────────────────────────────────
/coverage

# ─── Misc ────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ─── Debug logs ──────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Vercel ──────────────────────────────────────────────
.vercel

